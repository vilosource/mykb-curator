# Curator-ready MediaWiki — test fixture AND hand-runnable dev wiki.
#
# SQLite-backed (no companion DB), uploads enabled, Admin promoted to
# the bot group. All of that is done by bootstrap.sh on first boot
# (the single source of truth — the scenario fixture builds + runs
# this image rather than re-implementing the sequence in Go).
#
# Idempotent first-boot install; port-agnostic $wgServer. See
# bootstrap.sh. No LocalSettings.php is baked in on purpose: it is
# generated by install.php at first boot, and its presence is the
# idempotency marker.

FROM mediawiki:1.41

# /var/www/data holds the SQLite DB; the base image doesn't pre-create
# it. Real install happens at first boot (needs no build-time DB).
RUN install -d -o www-data -g www-data /var/www/data

COPY bootstrap.sh /usr/local/bin/bootstrap.sh
RUN chmod +x /usr/local/bin/bootstrap.sh

# Defaults match the scenario fixture's constants so existing L4
# tests keep passing unchanged. Override via -e for other setups.
ENV MW_WIKI_NAME=ScenarioWiki \
    MW_ADMIN_USER=Admin \
    MW_ADMIN_PASS=adminpassword-9999

EXPOSE 80

# bootstrap.sh installs (first boot only) then exec's
# apache2-foreground, so the wiki serves on :80 once ready.
ENTRYPOINT ["/usr/local/bin/bootstrap.sh"]
